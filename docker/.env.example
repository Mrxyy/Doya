# Browser-visible daemon host. Use host:port, http://host:port, or https://host.
DOYA_PUBLIC_DAEMON=localhost:6767

# Browser-visible control API URL.
DOYA_PUBLIC_CONTROL_API_URL=http://localhost:6777

# Origins allowed to call the daemon from a browser.
DOYA_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Host headers accepted by the daemon. Use comma-separated hostnames or true.
DOYA_HOSTNAMES=localhost,127.0.0.1

# Optional image names for registry-based production deploys.
DOYA_SERVER_IMAGE=jadenxiong/doya-server:latest
DOYA_CONTROL_IMAGE=jadenxiong/doya-control:latest
DOYA_APP_IMAGE=jadenxiong/doya-app:latest

# Runtime scheduler node registration. Endpoint is used by control to call the daemon.
# Public endpoint is returned to browser clients by the scheduler when set.
DOYA_RUNTIME_NODE_EMAIL=runtime-node@doya.local
DOYA_RUNTIME_NODE_ID=local-docker
DOYA_RUNTIME_NODE_ENDPOINT=http://localhost:6767
DOYA_RUNTIME_NODE_PUBLIC_ENDPOINT=

# Optional host Codex install mounted into the production server container.
DOYA_CODEX_HOME=/root/.codex
DOYA_CODEX_BIN=/root/.codex/standalone/releases/0.139.0-x86_64-unknown-linux-musl/bin/codex

# Optional SMS login provider credentials. These belong to the control service.
DOYA_DOTSMS_APIKEY=
DOYA_DOTSMS_SECRET=
DOYA_DOTSMS_SIGN_ID=
DOYA_DOTSMS_TEMPLATE_ID=
DOYA_DOTSMS_URL=

# Optional payment provider credentials. These belong to the control service.
DOYA_PAYMENT_MERCHANT_ID=
DOYA_PAYMENT_MERCHANT_KEY=
DOYA_PAYMENT_PUBLIC_BASE_URL=
DOYA_PAYMENT_GATEWAY_BASE_URL=
DOYA_PAYMENT_NOTIFY_URL=
DOYA_PAYMENT_RETURN_URL=

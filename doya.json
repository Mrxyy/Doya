{
  "worktree": {
    "setup": [
      "npm ci",
      "npm run build:server",
      "cp \"$DOYA_SOURCE_CHECKOUT_PATH/packages/server/.env\" \"$DOYA_WORKTREE_PATH/packages/server/.env\""
    ]
  },
  "scripts": {
    "daemon": {
      "type": "service",
      "command": "DOYA_LISTEN=0.0.0.0:$DOYA_PORT ./scripts/dev-daemon.sh"
    },
    "app": {
      "type": "service",
      "command": "cd packages/app && BROWSER=none EXPO_PUBLIC_LOCAL_DAEMON=\"localhost:${DOYA_SERVICE_DAEMON_PORT}\" npx expo start --port $DOYA_PORT"
    },
    "typecheck": {
      "command": "npm run typecheck"
    }
  }
}

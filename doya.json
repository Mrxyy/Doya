{
  "worktree": {
    "setup": [
      "npm ci",
      "npm run build:server",
      "cp \"$DOYA_SOURCE_CHECKOUT_PATH/packages/server/.env\" \"$DOYA_WORKTREE_PATH/packages/server/.env\""
    ]
  },
  "scripts": {
    "daemon": {
      "type": "service",
      "command": "DOYA_LISTEN=0.0.0.0:$DOYA_PORT ./scripts/dev-daemon.sh"
    },
    "control": {
      "type": "service",
      "command": "DOYA_CONTROL_HOST=127.0.0.1 DOYA_CONTROL_PORT=$DOYA_PORT npm run dev:control"
    },
    "app": {
      "type": "service",
      "command": "cd packages/app && BROWSER=none EXPO_PUBLIC_LOCAL_DAEMON=\"${EXPO_PUBLIC_LOCAL_DAEMON:-localhost:${DOYA_SERVICE_DAEMON_PORT:-6767}}\" EXPO_PUBLIC_CONTROL_API_URL=\"http://localhost:${DOYA_SERVICE_CONTROL_PORT}\" npx expo start --port $DOYA_PORT"
    },
    "typecheck": {
      "command": "npm run typecheck"
    }
  }
}
